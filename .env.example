DATABASE_URL=postgresql://cloudgeniee:changeme@localhost:5432/cloudgeniee
REDIS_URL=redis://localhost:6379

# S3 + SQS → shaheen AWS account
AWS_PROFILE=shaheen
AWS_REGION=us-east-1

# Bedrock → kickid AWS account (needs Bedrock quota)
BEDROCK_AWS_PROFILE=kickid
BEDROCK_REGION=us-east-1

S3_BUCKET_NAME=your-bucket-name
SQS_INGESTION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/cloudgeniee-ingestion.fifo

# LLM options: amazon.nova-lite-v1:0 | amazon.nova-pro-v1:0 | qwen.qwen3-32b-v1:0
#              mistral.mistral-large-3-675b-instruct | deepseek.v3.2
BEDROCK_LLM_MODEL=mistral.mistral-large-3-675b-instruct
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_DIMENSIONS=1024

# SMTP — use a Gmail app password (not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=CloudGeniee <your-email@gmail.com>
DASHBOARD_URL=http://localhost:3000

API_PORT=3001
API_PUBLIC_URL=http://localhost:3001
# Generate with: openssl rand -hex 32
API_SECRET=change-this-to-a-long-random-string
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
