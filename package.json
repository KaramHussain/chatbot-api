{
  "name": "@cloudgeniee/api",
  "version": "0.1.0",
  "description": "CloudGeniee API — multi-tenant AI chatbot backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate && tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.782.0",
    "@aws-sdk/client-s3": "^3.782.0",
    "@aws-sdk/client-secrets-manager": "^3.782.0",
    "@aws-sdk/client-sqs": "^3.782.0",
    "@aws-sdk/credential-providers": "^3.782.0",
    "@aws-sdk/s3-request-presigner": "^3.782.0",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.11",
    "jose": "^5.10.0",
    "nodemailer": "^8.0.11",
    "postgres": "^3.4.5",
    "sharp": "^0.35.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.18",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
